# ============================================================
# KR Stock Autotrading — 환경변수 예시
# 복사 후 .env 로 이름 변경하여 사용 (절대 커밋 금지)
# ============================================================

# ── 거래 모드 ─────────────────────────────────────────────
# paper (모의투자) | live
TRADING_MODE=paper

# ── 전략 설정 ─────────────────────────────────────────────
ACTIVE_STRATEGY=rsi_macd
STRATEGY_PARAMS={"rsi_period": 14, "rsi_oversold": 35, "rsi_overbought": 65, "fast_period": 12, "slow_period": 26, "signal_period": 9, "sl_atr_mult": 2.0, "tp1_atr_mult": 3.0, "tp2_atr_mult": 5.0, "vol_multiplier": 1.3}

# ── 리스크 파라미터 ───────────────────────────────────────
RISK_PER_TRADE=0.01
MAX_POSITIONS=5
DAILY_LOSS_LIMIT=0.05

# ── 시장 설정 ────────────────────────────────────────────
# KOSPI | KOSDAQ | BOTH
MARKET=BOTH
ALLOW_OVERNIGHT=false
FORCE_CLOSE_TIME=15:20

# ── 데이터베이스 ──────────────────────────────────────────
SQLITE_DB_PATH=/data/trading.db

# ── 로깅 ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── KIS API ───────────────────────────────────────────────
# 한국투자증권 Open API (paper/live 공통 appkey 사용)
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
# 계좌번호 형식: XXXXXXXXXX-XX  (앞 10자리-뒤 2자리)
KIS_ACCOUNT_NO=1234567890-01

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
